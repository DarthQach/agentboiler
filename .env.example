APP_ENV=development # Runtime environment: development, staging, or production.
SUPABASE_URL= # Supabase project URL from Project Settings > API.
SUPABASE_SERVICE_KEY= # Supabase service role key from Project Settings > API.
OPENAI_API_KEY= # OpenAI API key from the OpenAI dashboard.
ANTHROPIC_API_KEY= # Anthropic API key from the Anthropic Console.
STRIPE_SECRET_KEY= # Stripe secret key from Developers > API keys.
STRIPE_WEBHOOK_SECRET= # Stripe webhook signing secret from Developers > Webhooks.
