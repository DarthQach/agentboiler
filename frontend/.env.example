### App
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Public URL of this frontend

### API
NEXT_PUBLIC_API_URL=http://localhost:8000 # URL of the FastAPI backend

### Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co # Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_... # Publishable key - safe to expose client-side
SUPABASE_URL=https://xxxx.supabase.co # Supabase project Settings > API, used by Next.js server routes
SUPABASE_SECRET_KEY=sb_secret_... # Secret key for Next.js server routes only. Never expose client-side.

### Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... # Stripe Dashboard > Developers > API keys. Safe to expose client-side.
