### App
APP_ENV=development # "development" or "production"
APP_SECRET_KEY=your-secret-key-here # Generate with: openssl rand -hex 32

### PydanticAI / LLM
ANTHROPIC_API_KEY=sk-ant-... # From https://console.anthropic.com
OPENAI_API_KEY=sk-... # Optional - only if swapping to OpenAI
DEFAULT_MODEL=claude-sonnet-4-5 # Model identifier - see CUSTOMIZATION.md to swap
AGENT_MAX_TOOL_RETRIES=3 # Max retries on a rejected tool before agent gives up

### Supabase
SUPABASE_URL=https://xxxx.supabase.co # Supabase project Settings > API
SUPABASE_SECRET_KEY=sb_secret_... # Secret key - Settings > API Keys. Never expose client-side.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_... # Publishable key - Settings > API Keys

### Stripe
STRIPE_SECRET_KEY=sk_test_... # Stripe Dashboard > Developers > API keys
STRIPE_WEBHOOK_SECRET=whsec_... # Stripe Dashboard > Webhooks > your endpoint > Signing secret
STRIPE_STARTER_PRICE_ID=price_... # Price ID for Starter plan ($29/mo)
STRIPE_PRO_PRICE_ID=price_... # Price ID for Pro plan ($79/mo)
STRIPE_STARTER_TOOL_CALL_LIMIT=500 # Monthly tool call cap for Starter plan
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success # Redirect URL after successful Checkout completion
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel # Redirect URL when the buyer cancels Checkout

### CORS
ALLOWED_ORIGINS=http://localhost:3000 # Comma-separated allowed frontend origins
